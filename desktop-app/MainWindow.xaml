<Window x:Name="Dashboard" x:Class="WebStoreManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WebStoreManagementApp" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Aplikacija za upravljanje veb prodavnicom" Height="800" Width="1440" Icon="/Resources/logo.png" WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Grid Background="{StaticResource AccentColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PageHeaderBg}" Grid.Column="0" Grid.Row="1">
            <StackPanel>
                <Button x:Name="ProizvodiBtn" Content="Proizvodi" Style="{StaticResource SidebarButton}" Click="ProizvodiBtn_Click"/>
                <Button x:Name="NarudzbineBtn" Content="Narudžbine" Style="{StaticResource SidebarButton}" Click="NarudzbineBtn_Click"/>
                <Button x:Name="DostavaBtn" Content="Metode dostave" Style="{StaticResource SidebarButton}" Click="DostavaBtn_Click"/>
                <Button x:Name="KategorijaBtn" Content="Kategorije" Style="{StaticResource SidebarButton}" Click="KategorijaBtn_Click"/>
            </StackPanel>
        </Border>

        <Grid x:Name="Header" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Background="{StaticResource PageHeaderBg}">
            <Image Source="/Resources/logo.png" Width="200" Height="55" HorizontalAlignment="Left" Margin="30,0,0,0"/>
            <Label x:Name="CurrentGridLabel" Content="Proizvodi" Foreground="White" Margin="0,0,75,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="ContentGrid" Grid.Column="1" Grid.Row="1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>

    </Grid>
</Window>
    
    
