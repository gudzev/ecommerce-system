<Page x:Class="DesktopApp.Pages.DeliveryMethodsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DesktopApp.Pages"
      mc:Ignorable="d" 
      Title="DeliveryMethodsPage" Loaded="DeliveryMethodsPageLoaded">

    <Grid x:Name="Dostava" Grid.Column="1" Grid.Row="1" Background="{StaticResource HeaderLinksBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Label Content="Cena po artiklu za dostavu" Grid.Column="0" Grid.Row="0" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="pricePerProductTextBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox}"/>

        <Label Content="Ime opcije za dostavu" Grid.Column="0" Grid.Row="1" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="optionNameTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox}"/>

        <Label Content="Min. vrednost za besplatnu dostavu" Grid.Column="0" Grid.Row="2" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="minimumValueTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource TextBox}"/>

        <Button x:Name="methodAddBtn" Content="Dodaj metodu" Grid.Column="2" Grid.Row="0" Style="{StaticResource Btn}" Click="methodAddBtn_Click"/>
        <Button x:Name="methodUpdateBtn" Content="Izmeni metodu" Grid.Column="2" Grid.Row="1" Style="{StaticResource Btn}" Click="methodUpdateBtn_Click"/>
        <Button x:Name="methodDeleteBtn" Content="Obriši metodu" Grid.Column="2" Grid.Row="2" Style="{StaticResource Btn}" Click="methodDeleteBtn_Click"/>

        <DataGrid x:Name="MethodsTable" SelectionUnit="FullRow" AutoGenerateColumns="False" Grid.ColumnSpan="3" Grid.Row="5" IsReadOnly="True" SelectionChanged="LoadMethodsRow" SelectionMode="Single" HorizontalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="auto"/>
                <DataGridTextColumn Header="Cena po proizvodu" Binding="{Binding price_per_item}" Width="auto"/>
                <DataGridTextColumn Header="Ime metode" Binding="{Binding name}" Width="auto"/>
                <DataGridTextColumn Header="Min. vrednost za besplatnu dostavu" Binding="{Binding free_shipping_minimum_value}" Width="auto"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>
