<Page x:Class="DesktopApp.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DesktopApp.Pages"
      mc:Ignorable="d" 
      Title="ProductsPage" Loaded="ProductsPageLoaded">

    <Grid x:Name="Proizvodi" Grid.Column="1" Grid.Row="1" Background="{StaticResource HeaderLinksBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"></ColumnDefinition>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Button x:Name="productAddBtn" Content="Dodaj proizvod" Grid.Column="2" Grid.Row="0" Style="{StaticResource Btn}" Click="productAddBtn_Click"/>
        <Button x:Name="productUpdateBtn" Content="Izmeni proizvod" Grid.Column="2" Grid.Row="1" Style="{StaticResource Btn}" Click="productUpdateBtn_Click"/>
        <Button x:Name="productDeactivateBtn" Content="Deaktiviraj proizvod" Grid.Column="2" Grid.Row="2" Style="{StaticResource Btn}" Click="productDeactivateBtn_Click" />
        <Button x:Name="productActivateBtn" Content="Aktiviraj proizvod" Grid.Column="2" Grid.Row="3" Style="{StaticResource Btn}" Click="productActivateBtn_Click"/>

        <Label Content="Naziv proizvoda" Grid.Column="0" Grid.Row="0" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="productNameTextBox" Grid.Column="1" Grid.Row="0" Style="{StaticResource TextBox}"/>

        <Label Content="Link do slike" Grid.Column="0" Grid.Row="1" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="imageURLTextBox" Grid.Column="1" Grid.Row="1" Style="{StaticResource TextBox}"/>

        <Label Content="Normalna cena" Grid.Column="0" Grid.Row="2" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="priceTextBox" Grid.Column="1" Grid.Row="2" Style="{StaticResource TextBox}"/>

        <Label Content="Cena ako je na popustu" Grid.Column="0" Grid.Row="3" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="salePriceTextBox" Grid.Column="1" Grid.Row="3" Style="{StaticResource TextBox}"/>

        <Label Content="Kategorija" Grid.Column="0" Grid.Row="4" Style="{StaticResource TextBoxLabel}"/>
        <ComboBox x:Name="categoryComboBox" Grid.Column="1" Grid.Row="4" Style="{StaticResource ComboBox}"/>

        <Label Content="Količina na stanju" Grid.Column="0" Grid.Row="5" Style="{StaticResource TextBoxLabel}"/>
        <TextBox x:Name="quantityTextBox" Grid.Column="1" Grid.Row="5" Style="{StaticResource TextBox}"/>

        <DataGrid x:Name="ProductsTable" SelectionUnit="FullRow" AutoGenerateColumns="False" Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="6" IsReadOnly="True" SelectionMode="Single" HorizontalAlignment="Stretch" SelectionChanged="LoadProductsRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="auto"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding name}" Width="auto"/>
                <DataGridTextColumn Header="Slika" Binding="{Binding image_url}" Width="200"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding price_rsd}" Width="auto"/>
                <DataGridTextColumn Header="Popust" Binding="{Binding price_on_sale}" Width="auto"/>
                <DataGridTextColumn Header="ID Kategorije" Binding="{Binding category_id}" Width="90"/>
                <DataGridTextColumn Header="Na stanju" Binding="{Binding stock_quantity}" Width="90"/>
                <DataGridCheckBoxColumn Header="Aktivan" Binding="{Binding is_active}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
